<view wx:if="{{view}}" class="page-shell result-page">
  <view class="result-summary card">
    <view class="result-type">{{view.typeLabel}}</view>
    <view class="result-text">{{view.summaryText}}</view>
    <view class="result-tags">
      <text class="pill">{{view.roundLabel}}</text>
      <text wx:if="{{view.mainWinLabel}}" class="pill">{{view.mainWinLabel}}</text>
      <text class="pill">庄底 {{view.bankerBase}}</text>
      <text class="pill">金牌 {{view.goldTileLabel}}</text>
      <text wx:if="{{view.goldDiceLabel}}" class="pill">骰子 {{view.goldDiceLabel}}</text>
      <text wx:if="{{view.winnerLabel}}" class="pill">赢家 {{view.winnerLabel}}</text>
      <text wx:if="{{view.sourceSeatLabel}}" class="pill">{{view.sourceSeatRoleLabel}} {{view.sourceSeatLabel}}</text>
      <text wx:if="{{view.winningTileLabel}}" class="pill">胡牌 {{view.winningTileLabel}}</text>
      <text wx:if="{{view.nextDealerLabel}}" class="pill">下局庄 {{view.nextDealerLabel}}</text>
    </view>
    <view wx:if="{{view.matchEnded}}" class="match-end-tip">有玩家积分小于等于 0，本场已结束。</view>
  </view>

  <view class="detail-card card">
    <view class="section-title">主结算</view>
    <view class="detail-text">{{view.mainSettlementText}}</view>
  </view>

  <view wx:if="{{view.pairwiseTransferTexts.length}}" class="detail-card card">
    <view class="section-title">未胡三家番差</view>
    <view wx:for="{{view.pairwiseTransferTexts}}" wx:key="index" class="detail-line">{{item}}</view>
  </view>

  <view class="score-card card">
    <view class="section-title">积分变化</view>
    <view wx:for="{{view.seatResults}}" wx:key="seatId" class="score-row {{item.isPositiveDelta ? 'score-row-win' : ''}} {{item.isNegativeDelta ? 'score-row-lose' : ''}}">
      <view class="score-main">
        <view class="score-name-row">
          <view class="score-name">{{item.displayName}}</view>
          <text class="score-wind">{{item.windLabel}}</text>
          <text wx:if="{{item.isNextDealer}}" class="dealer-pill">下局庄</text>
        </view>
        <view class="score-meta">总分 {{item.scoreFlowText}} · {{item.fanText}}</view>
        <view class="score-meta">番项 {{item.fanItemsText}}</view>
      </view>
      <view class="score-delta">{{item.deltaText}}</view>
    </view>
  </view>

  <view class="seat-card card">
    <view class="section-title">终局牌面</view>
    <view wx:for="{{view.seatResults}}" wx:key="seatId" class="seat-block">
      <view class="seat-block-name">{{item.displayName}} · {{item.windLabel}}</view>
      <view class="seat-line">手牌：{{item.concealedLabels.length ? item.concealedLabels.join(' ') : '无'}}</view>
      <view class="seat-line">副露：{{item.meldTexts.length ? item.meldTexts.join(' / ') : '无'}}</view>
      <view class="seat-line">花牌：{{item.flowerLabels.length ? item.flowerLabels.join(' ') : '无'}}</view>
      <view class="seat-line">弃牌：{{item.discardLabels.length ? item.discardLabels.join(' ') : '无'}}</view>
    </view>
  </view>

  <view class="logs-card card">
    <view class="section-title">最近动作</view>
    <view wx:for="{{view.recentLogs}}" wx:key="id" class="log-item">{{item.text}}</view>
  </view>

  <view class="button-group">
    <button class="primary-btn" bindtap="onReplay" disabled="{{navigating}}">{{view.replayButtonText}}</button>
    <button class="secondary-btn" bindtap="onBackHome" disabled="{{navigating}}">返回首页</button>
  </view>
</view>
