<view wx:if="{{view}}" class="page-shell table-page">
  <view class="top-bar card">
    <view class="top-item">
      <text class="top-label">局数</text>
      <text class="top-value">{{view.roundLabel}}</text>
    </view>
    <view class="top-item">
      <text class="top-label">庄家</text>
      <text class="top-value">{{view.dealerLabel}}</text>
    </view>
    <view class="top-item">
      <text class="top-label">庄底</text>
      <text class="top-value">{{view.bankerBaseLabel}}</text>
    </view>
    <view class="top-item">
      <text class="top-label">金牌</text>
      <text class="top-value">{{view.goldTileLabel}}</text>
      <text wx:if="{{view.goldDiceLabel}}" class="top-subvalue">{{view.goldDiceLabel}}</text>
    </view>
    <view class="top-item">
      <text class="top-label">剩余牌</text>
      <text class="top-value">{{view.remainingCount}}</text>
    </view>
  </view>

  <view class="status-card card">
    <view class="section-title">当前状态</view>
    <view class="status-text">{{view.statusText}}</view>
  </view>

  <view class="table-stage card">
    <view class="stage-top">
      <seat-summary seat="{{view.topSeat}}" position="top" />
    </view>

    <view class="stage-middle">
      <view class="side-seat left-seat">
        <seat-summary seat="{{view.leftSeat}}" position="left" />
      </view>

      <view class="center-board">
        <view class="section-title">最近动作</view>
        <view wx:for="{{view.recentLogs}}" wx:key="id" class="log-item">{{item.text}}</view>
      </view>

      <view class="side-seat right-seat">
        <seat-summary seat="{{view.rightSeat}}" position="right" />
      </view>
    </view>
  </view>

  <view class="human-panel card">
    <view class="human-header">
      <view class="human-name-wrap">
        <text class="human-name">{{view.bottomSeat.displayName}}</text>
        <text class="pill">{{view.bottomSeat.windLabel}}</text>
        <text wx:if="{{view.humanSpecialStateLabel}}" class="pill">{{view.humanSpecialStateLabel}}</text>
        <text wx:if="{{view.bottomSeat.isDealer}}" class="dealer-badge">庄</text>
      </view>
      <text class="human-score">{{view.humanScoreText}}</text>
    </view>

    <view wx:if="{{view.humanMeldTexts.length}}" class="meta-group">
      <text class="meta-title">副露</text>
      <view class="tag-wrap">
        <text wx:for="{{view.humanMeldTexts}}" wx:key="index" class="meta-tag">{{item}}</text>
      </view>
    </view>

    <view wx:if="{{view.humanFlowers.length}}" class="meta-group">
      <text class="meta-title">花牌</text>
      <view class="tag-wrap">
        <text wx:for="{{view.humanFlowers}}" wx:key="index" class="meta-tag meta-tag-flower">{{item}}</text>
      </view>
    </view>

    <view class="meta-group">
      <text class="meta-title">手牌</text>
      <scroll-view scroll-x="true" class="hand-scroll">
        <view class="hand-list">
          <tile wx:for="{{view.humanHand}}" wx:key="id" tile="{{item}}" disabled="{{acting || item.disabled}}" bind:tiletap="onTileTap" />
        </view>
      </scroll-view>
    </view>

    <view class="hand-actions">
      <button class="secondary-btn discard-btn {{acting ? 'page-btn-disabled' : ''}}" bindtap="onDiscardTap" disabled="{{acting || view.discardDisabled || !view.canDiscard}}">
        {{view.discardButtonText}}
      </button>
      <action-panel actions="{{view.availableActions}}" disabled="{{acting}}" bind:actiontap="onActionTap" />
    </view>
  </view>
</view>

<view wx:else class="page-shell loading-page">
  <view class="card loading-card">正在加载牌局...</view>
</view>
