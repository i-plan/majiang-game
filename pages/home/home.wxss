.home-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  justify-content: center;
}

.hero,
.intro {
  padding: 30rpx;
}

.hero-title {
  font-size: 58rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: rgba(247, 240, 220, 0.84);
  font-size: 28rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 26rpx 0 24rpx;
}

.selector-block {
  margin-bottom: 30rpx;
}

.option-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.option-chip {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 18rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.09);
  border: 2rpx solid rgba(255, 255, 255, 0.16);
  color: rgba(247, 240, 220, 0.92);
  font-weight: 600;
}

.option-chip-active {
  background: rgba(240, 194, 97, 0.18);
  border-color: rgba(240, 194, 97, 0.42);
  color: #f5d58b;
}

.intro-item {
  margin-top: 16rpx;
  color: rgba(247, 240, 220, 0.9);
  line-height: 1.7;
}
