.home-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  justify-content: center;
}

.hero,
.intro {
  padding: 30rpx;
}

.hero-title {
  font-size: 58rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: rgba(247, 240, 220, 0.72);
  font-size: 28rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 26rpx 0 34rpx;
}

.intro-item {
  margin-top: 16rpx;
  color: rgba(247, 240, 220, 0.82);
  line-height: 1.7;
}
