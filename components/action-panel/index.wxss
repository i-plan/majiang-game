.action-panel {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.action-btn {
  min-width: 132rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 18rpx;
  border: none;
  border-radius: 18rpx;
  background: rgba(240, 194, 97, 0.18);
  color: #f8df9d;
  font-size: 26rpx;
  font-weight: 700;
}
