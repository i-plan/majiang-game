@import "./styles/variables.wxss";

page {
  min-height: 100%;
  background: var(--page-bg);
  color: var(--text-primary);
  font-size: 28rpx;
}

view,
text,
button {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx;
}

.card {
  background: var(--card-bg);
  border: 2rpx solid var(--card-border);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.16);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  color: var(--text-secondary);
  font-size: 22rpx;
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f8d774, #efb245);
  color: #342100;
  font-size: 30rpx;
  font-weight: 700;
}

.secondary-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.06);
  color: var(--text-primary);
  font-size: 28rpx;
}
