page {
  min-height: 100%;
  background: linear-gradient(180deg, #0d4b3b 0%, #0a2e26 100%);
  color: #f7f0dc;
  font-size: 28rpx;
}

view,
text,
button {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx;
}

.card {
  background: rgba(16, 51, 41, 0.88);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.16);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(247, 240, 220, 0.86);
  font-size: 22rpx;
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f8d774, #efb245);
  color: #342100;
  font-size: 30rpx;
  font-weight: 700;
}

.secondary-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.06);
  color: #f7f0dc;
  font-size: 28rpx;
}

.page-btn-disabled {
  opacity: 0.56;
}
