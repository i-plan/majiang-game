<view class="seat-summary card {{seat.isActive ? 'seat-active' : ''}}">
  <view class="seat-head">
    <view class="seat-name">{{seat.displayName}}</view>
    <view class="seat-badges">
      <text class="pill">{{seat.windLabel}}</text>
      <text wx:if="{{seat.specialStateLabel}}" class="pill">{{seat.specialStateLabel}}</text>
      <text wx:if="{{seat.isDealer}}" class="dealer-badge">庄</text>
    </view>
  </view>

  <view class="seat-meta-row">
    <text class="seat-line">手牌 {{seat.concealedCount}} 张</text>
    <text class="seat-score">{{seat.scoreText}}</text>
  </view>

  <view wx:if="{{seat.pendingDeltaText}}" class="seat-delta {{seat.pendingDelta > 0 ? 'seat-delta-positive' : seat.pendingDelta < 0 ? 'seat-delta-negative' : ''}}">
    本局 {{seat.pendingDeltaText}}
  </view>

  <view wx:if="{{seat.meldTexts.length}}" class="seat-group">
    <text class="seat-group-title">副露</text>
    <view class="chip-list">
      <text wx:for="{{seat.meldTexts}}" wx:key="index" class="chip">{{item}}</text>
    </view>
  </view>

  <view wx:if="{{seat.flowerLabels.length}}" class="seat-group">
    <text class="seat-group-title">花牌</text>
    <view class="chip-list">
      <text wx:for="{{seat.flowerLabels}}" wx:key="index" class="chip chip-flower">{{item}}</text>
    </view>
  </view>

  <view class="seat-group">
    <text class="seat-group-title">弃牌</text>
    <view class="chip-list discard-list">
      <text wx:if="{{!seat.discardLabels.length}}" class="empty-text">暂无</text>
      <text wx:for="{{seat.discardLabels}}" wx:key="index" class="chip chip-discard">{{item}}</text>
    </view>
  </view>
</view>
